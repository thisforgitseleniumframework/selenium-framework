<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Suite" parallel="tests" thread-count="2">

  <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
    </listeners>

    <test name="Chrome Test">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.framework.tests.LoginTest"/>
            <class name="com.framework.tests.ForgotPasswordTest"/>
        </classes>
    </test>

   <!--  <test name="Firefox Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.framework.tests.LoginTest"/>
        </classes>
    </test> -->

</suite>
